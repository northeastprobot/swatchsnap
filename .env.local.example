# SwatchSnap Environment Variables
# Copy this file to .env.local and fill in the values

# Replicate API — get your token at https://replicate.com/account
REPLICATE_API_TOKEN=

# Webhook URL for lead capture (e.g., Zapier, Make, or your own endpoint)
LEAD_WEBHOOK_URL=

# Resend API key for email confirmations — get one at https://resend.com
RESEND_API_KEY=
